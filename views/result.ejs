<!DOCTYPE html>
<html>
<head>
<title>Scholarship Result</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<div class="container mt-5">
    <div class="card shadow-lg border-0 p-4 mx-auto" style="max-width:600px;border-radius:20px;">

        <div class="text-center">
            <h2>🎓 Scholarship Status</h2>
            <p class="text-muted">SC/ST Student Scholarship Details</p>
        </div>

        <hr>

        <h5>Name: <b><%= student.name %></b></h5>
        <p>Aadhaar: <%= student.aadhaar %></p>
        <p>College: <%= student.college %></p>
        <p>Course: <%= student.course %></p>
        <p>Amount: ₹<%= student.amount %></p>

        <p>
            Status:
            <% if(student.status === "Success") { %>
                <span class="badge bg-success">Success</span>
            <% } else if(student.status === "Failed") { %>
                <span class="badge bg-danger">Failed</span>
            <% } else if(student.status === "Processed") { %>
                <span class="badge bg-info">Processed</span>
            <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
            <% } %>
        </p>

        <button onclick="window.print()" class="btn btn-primary w-100 mt-3">
            🖨️ Print Receipt
        </button>

        <a href="/" class="btn btn-secondary w-100 mt-2">Back Home</a>

    </div>
</div>

</body>
</html>