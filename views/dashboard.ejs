<!DOCTYPE html>
<html>
<head>
    <title>College Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<nav class="navbar navbar-dark bg-primary px-4 shadow">
    <span class="navbar-brand fw-bold">🎓 PNSSET Admin Dashboard</span>
    <a href="/logout" class="btn btn-light btn-sm">Logout</a>
</nav>

<div class="container-fluid mt-4 px-4">

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow border-0 p-3">
                <h6>Total Students</h6>
                <h2 class="text-primary"><%= students.length %></h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 p-3">
                <h6>Total Notices</h6>
                <h2 class="text-success"><%= notices.length %></h2>
            </div>
        </div>
    </div>

    <div class="card shadow border-0 p-4 mb-4">
        <h4>➕ Add Scholarship Record</h4>

        <form method="POST" action="/add" class="row g-3 mt-2">
            <div class="col-md-4">
                <input name="name" class="form-control" placeholder="Student Name" required>
            </div>

            <div class="col-md-4">
                <input name="aadhaar" class="form-control" placeholder="Aadhaar Number" required>
            </div>

            <div class="col-md-4">
                <input name="phone" class="form-control" placeholder="WhatsApp Number e.g. 919876543210" required>
            </div>

            <div class="col-md-4">
                <input name="college" class="form-control" placeholder="College Name" required>
            </div>

            <div class="col-md-4">
                <input name="course" class="form-control" placeholder="Course" required>
            </div>

            <div class="col-md-4">
                <input name="amount" class="form-control" placeholder="Scholarship Amount" required>
            </div>

            <div class="col-md-4">
                <select name="status" class="form-select">
                    <option>Pending</option>
                    <option>Processed</option>
                    <option>Success</option>
                    <option>Failed</option>
                </select>
            </div>

            <div class="col-12">
                <button class="btn btn-primary w-100 fw-bold">Add Student</button>
            </div>
        </form>
    </div>

    <div class="card shadow border-0 p-4 mb-4">
        <h4>📢 Send Notice</h4>

        <form method="POST" action="/add-notice" class="row g-3 mt-2">
            <div class="col-md-4">
                <input name="title" class="form-control" placeholder="Notice Title" required>
            </div>

            <div class="col-md-6">
                <input name="message" class="form-control" placeholder="Notice Message" required>
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100 fw-bold">Send</button>
            </div>
        </form>
    </div>

    <div class="card shadow border-0 p-4 mb-4">
        <h4>📋 Sent Notices</h4>

        <% if(notices.length === 0) { %>
            <p class="text-muted">No notices available</p>
        <% } %>

        <% notices.forEach(n => { %>
            <div class="alert alert-info d-flex justify-content-between align-items-center">
                <div>
                    <b><%= n.title %></b><br>
                    <span><%= n.message %></span><br>
                    <small>Date: <%= n.date %></small>
                </div>

                <a href="/delete-notice/<%= n.id %>"
                   onclick="return confirm('Delete this notice?')"
                   class="btn btn-sm btn-danger">Delete</a>
            </div>
        <% }) %>
    </div>

    <div class="card shadow border-0 p-4 mb-4">
        <h4 class="mb-3">📲 Send Important WhatsApp Notice</h4>

        <form method="POST" action="/whatsapp-notice" class="row g-3">
            <div class="col-md-10">
                <input name="message" class="form-control"
                       placeholder="Type important message for all students" required>
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100 fw-bold">
                    Generate List
                </button>
            </div>
        </form>
    </div>

    <div class="card shadow border-0 p-4">
        <h4>📊 Student Scholarship Records</h4>

        <input type="text" id="searchInput" class="form-control my-3"
               placeholder="Search by Name, Aadhaar or Phone...">

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>Name</th>
                        <th>Aadhaar</th>
                        <th>Phone</th>
                        <th>College</th>
                        <th>Course</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="studentTable">
                    <% students.forEach(s => { %>
                    <tr>
                        <td><b><%= s.name %></b></td>
                        <td><%= s.aadhaar %></td>
                        <td><%= s.phone || "No Number" %></td>
                        <td><%= s.college %></td>
                        <td><%= s.course %></td>
                        <td>₹<%= s.amount %></td>

                        <td>
                            <% if(s.status === "Success") { %>
                                <span class="badge bg-success">Success</span>
                            <% } else if(s.status === "Failed") { %>
                                <span class="badge bg-danger">Failed</span>
                            <% } else if(s.status === "Processed") { %>
                                <span class="badge bg-info text-dark">Processed</span>
                            <% } else { %>
                                <span class="badge bg-warning text-dark">Pending</span>
                            <% } %>
                        </td>

                        <td>
                            <a href="/edit/<%= s.id %>" class="btn btn-sm btn-warning">Edit</a>
                            <a href="/delete/<%= s.id %>"
                               onclick="return confirm('Delete this student?')"
                               class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
document.getElementById("searchInput").addEventListener("keyup", function () {
    let value = this.value.toLowerCase();
    let rows = document.querySelectorAll("#studentTable tr");

    rows.forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(value)
            ? ""
            : "none";
    });
});
</script>

</body>
</html>