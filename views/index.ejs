<!DOCTYPE html>
<html>
<head>
    <title><%= settings.collegeName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background:#f5f8ff;
        }

        .hero-section {
            background: linear-gradient(120deg,#052c65,#0d6efd);
            min-height: 560px;
        }

        .hero-img {
            height: 330px;
            width: 100%;
            object-fit: cover;
            border-radius: 25px;
        }

        .nav-btn {
            border-radius: 8px;
            font-weight: 600;
        }

        .slider-img {
            height: 330px;
            object-fit: cover;
            border-radius: 20px;
        }

        .section-title {
            font-weight: 800;
            color: #052c65;
        }
    </style>
</head>

<body>

<!-- TOP BAR -->
<div class="bg-primary text-white py-2">
    <div class="container d-flex flex-wrap justify-content-between">
        <span>📞 <%= settings.phone %></span>
        <span>✉️ <%= settings.email %></span>
    </div>
</div>

<!-- CLEAN NAVBAR -->
<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/">
            🎓 <%= settings.collegeName %>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <div class="ms-auto d-flex flex-wrap gap-2 mt-3 mt-lg-0">
                <a href="/" class="btn btn-outline-primary btn-sm nav-btn">Home</a>
                <a href="/about" class="btn btn-outline-primary btn-sm nav-btn">About</a>
                <button onclick="openNoticeBox()" class="btn btn-outline-primary btn-sm nav-btn">Notice</button>
                <a href="/contact" class="btn btn-outline-primary btn-sm nav-btn">Contact</a>
                <a href="/student-register" class="btn btn-warning btn-sm nav-btn">Register</a>
                <a href="/student-login" class="btn btn-success btn-sm nav-btn">Student Login</a>
                <button onclick="openStatusBox()" class="btn btn-primary btn-sm nav-btn">Scholarship Status</button>
                <a href="/admin" class="btn btn-dark btn-sm nav-btn">Admin</a>
            </div>
        </div>
    </div>
</nav>

<!-- HERO -->
<section class="hero-section py-5">
    <div class="container text-white py-5">
        <div class="row align-items-center g-5">
            <div class="col-md-7">
                <span class="badge bg-warning text-dark mb-3">College Scholarship Management System</span>

                <h1 class="fw-bold display-5">
                    <%= settings.collegeName %> Scholarship Portal
                </h1>

                <p class="lead mt-3">
                    A digital platform for students to check scholarship details,
                    notices and payment status easily.
                </p>

                <div class="d-flex flex-wrap gap-3 mt-4">
                    <button onclick="openStatusBox()" class="btn btn-light btn-lg fw-bold">
                        Check Scholarship Status
                    </button>

                    <button onclick="openNoticeBox()" class="btn btn-outline-light btn-lg fw-bold">
                        View Notices
                    </button>

                    <a href="/student-register" class="btn btn-warning btn-lg fw-bold">
                        Register Now
                    </a>
                </div>
            </div>

            <div class="col-md-5">
                <img src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&w=900&q=80"
                     class="hero-img shadow-lg"
                     alt="College Campus">
            </div>
        </div>
    </div>
</section>

<!-- AUTO IMAGE SLIDER -->
<section class="py-5 bg-white">
    <div class="container">
        <h2 class="text-center section-title mb-4">Campus & Student Facilities</h2>

        <div id="campusSlider" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2500">
            <div class="carousel-inner rounded-4 shadow">

                <div class="carousel-item active">
                    <img src="https://images.unsplash.com/photo-1523580846011-d3a5bc25702b?auto=format&fit=crop&w=1200&q=80"
                         class="d-block w-100 slider-img"
                         alt="Students">
                </div>

                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1571260899304-425eee4c7efc?auto=format&fit=crop&w=1200&q=80"
                         class="d-block w-100 slider-img"
                         alt="Classroom">
                </div>

                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80"
                         class="d-block w-100 slider-img"
                         alt="Office">
                </div>

                <div class="carousel-item">
                    <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?auto=format&fit=crop&w=1200&q=80"
                         class="d-block w-100 slider-img"
                         alt="Graduation">
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#campusSlider" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#campusSlider" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
</section>

<!-- NOTICE -->
<div id="noticeBox" class="container my-5" style="display:none;">
    <div class="card shadow-lg border-0 p-4">
        <h3 class="text-center text-primary fw-bold">📢 Latest Notices</h3>

        <% if(notices.length === 0) { %>
            <div class="alert alert-warning text-center mt-3">No notice available right now.</div>
        <% } %>

        <% notices.forEach(n => { %>
            <div class="alert alert-info mt-3">
                <b><%= n.title %></b><br>
                <%= n.message %><br>
                <small>Published: <%= n.date %></small>
            </div>
        <% }) %>
    </div>
</div>

<!-- STATUS -->
<div id="statusBox" class="container my-5" style="display:none;">
    <div class="card shadow-lg border-0 p-4 mx-auto" style="max-width:560px;">
        <h3 class="text-center text-primary fw-bold">Scholarship Status Check</h3>
        <p class="text-muted text-center">Enter Aadhaar number to view details</p>

        <form method="POST" action="/check">
            <input name="aadhaar" class="form-control form-control-lg mb-3"
                   placeholder="Enter Aadhaar Number" required>

            <button class="btn btn-primary btn-lg w-100 fw-bold">
                View Scholarship Details
            </button>
        </form>
    </div>
</div>

<!-- FOOTER -->
<footer class="bg-dark text-white pt-5 pb-3">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5 class="fw-bold"><%= settings.collegeName %></h5>
                <p>Digital scholarship support system for students.</p>
            </div>

            <div class="col-md-4">
                <h5 class="fw-bold">Quick Links</h5>
                <p><a href="/" class="text-white text-decoration-none">Home</a></p>
                <p><a href="/about" class="text-white text-decoration-none">About</a></p>
                <p><a href="/contact" class="text-white text-decoration-none">Contact</a></p>
            </div>

            <div class="col-md-4">
                <h5 class="fw-bold">Contact</h5>
                <p>📍 Kendrapara, Odisha</p>
                <p>📞 <%= settings.phone %></p>
                <p>✉️ <%= settings.email %></p>
            </div>
        </div>

        <hr>
        <p class="text-center mb-0">© 2026 Scholarship Management System</p>
    </div>
</footer>

<script>
function openStatusBox() {
    document.getElementById("statusBox").style.display = "block";
    document.getElementById("noticeBox").style.display = "none";
    document.getElementById("statusBox").scrollIntoView({ behavior: "smooth" });
}

function openNoticeBox() {
    document.getElementById("noticeBox").style.display = "block";
    document.getElementById("statusBox").style.display = "none";
    document.getElementById("noticeBox").scrollIntoView({ behavior: "smooth" });
}
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>