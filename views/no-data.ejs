<!DOCTYPE html>
<html>
<head>
    <title>No Data</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg,#eef3ff,#dbeafe);
        }

        .card-box {
            border-radius: 25px;
            box-shadow: 0 25px 70px rgba(0,0,0,.2);
            background: white;
        }
    </style>
</head>

<body>

<div class="card p-5 text-center card-box">

    <h1>❌</h1>

    <h3 class="text-danger fw-bold">No Scholarship Data Found</h3>

    <p class="text-muted mt-2">
        Your scholarship data is not yet verified by admin.
    </p>

    <p class="fw-bold">
        Aadhaar: <%= student.aadhaar %>
    </p>

    <div class="mt-3">
        <a href="/student-dashboard" class="btn btn-primary">Go Back</a>
        <a href="/logout" class="btn btn-dark">Logout</a>
    </div>

</div>

</body>
</html>