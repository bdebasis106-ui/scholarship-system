<!DOCTYPE html>
<html>
<head>
    <title>Notice Board</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#f5f8ff; display:flex; flex-direction:column; min-height:100vh;">

<nav class="navbar navbar-expand-lg bg-white shadow">
    <div class="container">
        <a href="/" class="navbar-brand fw-bold text-primary">
            🎓 PNSSET Scholarship Portal
        </a>

        <div class="ms-auto d-flex gap-2">
            <a href="/" class="btn btn-outline-primary btn-sm">Home</a>
            <a href="/about" class="btn btn-outline-primary btn-sm">About</a>
            <a href="/contact" class="btn btn-outline-primary btn-sm">Contact</a>
            <a href="/admin" class="btn btn-danger btn-sm">Admin</a>
        </div>
    </div>
</nav>

<main class="flex-grow-1">

    <section class="py-5" style="background:linear-gradient(120deg,#083c8c,#0d6efd);">
        <div class="container text-white text-center">
            <h1 class="fw-bold">📢 Notice Board</h1>
            <p class="lead mb-0">Latest scholarship and college updates</p>
        </div>
    </section>

    <div class="container my-5">

        <% if(notices.length === 0) { %>
            <div class="alert alert-warning text-center shadow-sm">
                No notices available right now.
            </div>
        <% } %>

        <% notices.forEach(n => { %>
            <div class="card shadow border-0 mb-3">
                <div class="card-body p-4">
                    <h4 class="fw-bold text-primary"><%= n.title %></h4>
                    <p class="mb-2"><%= n.message %></p>
                    <span class="badge bg-secondary">Published on: <%= n.date %></span>
                </div>
            </div>
        <% }) %>

    </div>

</main>

<footer class="bg-dark text-white text-center py-3 mt-auto">
    © 2026 PNSSET Scholarship Portal
</footer>

</body>
</html>