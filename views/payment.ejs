<!DOCTYPE html>
<html>
<head>
    <title>Payment</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<div class="container mt-5">

    <div class="card shadow p-4 mx-auto text-center" style="max-width:500px;">
        <h3 class="text-primary mb-3">💳 Scholarship Payment</h3>

        <p><b>Name:</b> <%= student?.name || "Student" %></p>
        <p><b>Course:</b> <%= student?.course || "-" %></p>
        <p><b>Amount:</b> ₹<%= student?.amount || "0" %></p>

        <hr>

        <h5 class="text-success">📲 Scan & Pay (UPI / PhonePe)</h5>

        <!-- ✅ QR CODE (IMPORTANT FIX) -->
        <img src="/qr.jpeg" 
             class="img-fluid my-3 border rounded"
             style="max-height:300px;">

        <p class="text-muted">
            Scan this QR using PhonePe / Google Pay / Paytm
        </p>

        <!-- OPTIONAL -->
        <p><b>UPI ID:</b> debasis@upi</p>

        <!-- AFTER PAYMENT -->
        <a href="/payment-success" class="btn btn-success w-100">
            I Have Paid ✅
        </a>

        <!-- BACK BUTTON -->
        <a href="/student-dashboard" class="btn btn-secondary w-100 mt-2">
            ⬅ Back
        </a>

    </div>

</div>

</body>
</html>