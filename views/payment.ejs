<!DOCTYPE html>
<html>
<head>
    <title>Payment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<div class="container mt-5">

    <div class="card shadow p-4 mx-auto text-center" style="max-width:500px;">
        <h3 class="text-primary mb-3">💳 Scholarship Payment</h3>

        <p><b>Name:</b> <%= student.name %></p>
        <p><b>Course:</b> <%= student.course %></p>
        <p><b>Amount:</b> ₹<%= student.amount %></p>

        <hr>

        <h5 class="text-success">📲 Scan & Pay (PhonePe / UPI)</h5>

        <!-- QR CODE -->
        <img src="/qr.png" class="img-fluid my-3" style="max-height:300px;">

        <p class="text-muted">Scan this QR using PhonePe / Google Pay / Paytm</p>

        <!-- After payment -->
        <a href="/payment-success" class="btn btn-success w-100">
            I Have Paid ✅
        </a>

    </div>

</div>

</body>
</html>