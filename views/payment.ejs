<!DOCTYPE html>
<html>
<head>
    <title>Payment</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #eef3ff, #dbe6ff);
        }

        .payment-card {
            border-radius: 15px;
        }

        .qr-box {
            background: #fff;
            padding: 10px;
            border-radius: 10px;
            display: inline-block;
        }
    </style>
</head>

<body>

<div class="container mt-5">

    <div class="card shadow p-4 mx-auto text-center payment-card" style="max-width:500px;">
        
        <h3 class="text-primary mb-3">💳 Scholarship Payment</h3>

        <p><b>Name:</b> <%= student?.name || "Student" %></p>
        <p><b>Course:</b> <%= student?.course || "-" %></p>
        <p><b>Amount:</b> ₹<%= student?.amount || "0" %></p>

        <hr>

        <h5 class="text-success">📲 Scan & Pay (UPI / PhonePe)</h5>

        <div class="qr-box my-3">
            <img src="/qr.jpeg" 
                 class="img-fluid"
                 style="max-height:280px;"
                 onerror="this.src='https://via.placeholder.com/250?text=QR+Not+Found'">
        </div>

        <p class="text-muted">
            Scan this QR using PhonePe / Google Pay / Paytm
        </p>

        <p class="fw-bold text-dark">UPI ID: debasis@upi</p>

        <hr>

        <form method="POST" action="/pay" enctype="multipart/form-data">

            <div class="mb-3 text-start">
                <label class="form-label fw-bold">Upload Payment Screenshot</label>
                <input type="file" name="screenshot" class="form-control" required>
            </div>

            <button class="btn btn-success w-100">
                Submit Payment Proof ✅
            </button>

        </form>

        <a href="/student-dashboard" class="btn btn-secondary w-100 mt-2">
            ⬅ Back
        </a>

    </div>

</div>

</body>
</html>