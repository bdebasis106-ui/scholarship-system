<div class="card text-center shadow p-4" style="width:300px;margin:auto;">
    <img src="<%= student.photo %>" style="height:120px;border-radius:50%;">
    <h5 class="mt-2"><%= student.name %></h5>
    <p><%= student.course %></p>
    <p>Aadhaar: <%= student.aadhaar %></p>
    <p>Phone: <%= student.phone %></p>
    <button onclick="window.print()" class="btn btn-primary">Print</button>
</div>