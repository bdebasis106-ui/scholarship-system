<!DOCTYPE html>
<html>
<head>
    <title>ID Card</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #dbeafe, #eef2ff);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .id-card {
            width: 340px;
            border-radius: 25px;
            overflow: hidden;
            background: white;
            box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            transform: perspective(900px) rotateY(-5deg);
            border: 1px solid rgba(255,255,255,0.8);
        }

        .id-header {
            background: linear-gradient(135deg, #052c65, #0d6efd);
            color: white;
            padding: 22px;
            text-align: center;
        }

        .photo {
            width: 110px;
            height: 110px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid white;
            margin-top: -55px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.25);
            background: #fff;
        }

        .info-box {
            background: #f8fbff;
            border-radius: 15px;
            padding: 12px;
            margin-bottom: 10px;
            box-shadow: inset 0 1px 4px rgba(0,0,0,0.05);
        }

        .print-btn {
            border-radius: 12px;
            font-weight: bold;
        }

        @media print {
            body {
                background: white;
            }

            .print-btn {
                display: none;
            }

            .id-card {
                box-shadow: none;
                transform: none;
            }
        }
    </style>
</head>

<body>

<div class="text-center">

    <div class="id-card mx-auto">

        <div class="id-header">
            <h5 class="fw-bold mb-1"><%= student.college %></h5>
            <small>Student Identity Card</small>
        </div>

        <img src="<%= student.photo || 'https://via.placeholder.com/120' %>" class="photo">

        <div class="p-4">
            <h4 class="fw-bold text-primary mb-1"><%= student.name %></h4>
            <p class="text-muted mb-3"><%= student.course %></p>

            <div class="info-box text-start">
                <b>Aadhaar:</b> <%= student.aadhaar %>
            </div>

            <div class="info-box text-start">
                <b>Phone:</b> <%= student.phone %>
            </div>

            <div class="info-box text-start">
                <b>Status:</b> <%= student.status %>
            </div>

            <button onclick="window.print()" class="btn btn-primary w-100 print-btn mt-2">
                🖨 Print ID Card
            </button>
        </div>

    </div>

</div>

</body>
</html>