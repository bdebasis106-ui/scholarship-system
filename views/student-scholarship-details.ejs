<!DOCTYPE html>
<html>
<head>
    <title>Scholarship Details</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: radial-gradient(circle at top, #dbeafe, #f8fbff);
            font-family: Segoe UI, sans-serif;
        }

        .glass-card {
            border: 0;
            border-radius: 28px;
            background: rgba(255,255,255,.88);
            backdrop-filter: blur(14px);
            box-shadow: 0 25px 70px rgba(13,110,253,.18);
        }

        .hero {
            background: linear-gradient(135deg,#052c65,#0d6efd);
            color: white;
            border-radius: 30px;
            box-shadow: 0 30px 80px rgba(0,0,0,.25);
        }

        .info-card {
            border: 0;
            border-radius: 22px;
            box-shadow: 0 18px 45px rgba(0,0,0,.10);
            transition: .25s;
        }

        .info-card:hover {
            transform: translateY(-7px);
        }

        .amount-box {
            background: linear-gradient(135deg,#198754,#20c997);
            color: white;
            border-radius: 25px;
            box-shadow: 0 25px 55px rgba(25,135,84,.35);
        }

        .badge-3d {
            border-radius: 999px;
            padding: 9px 16px;
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

        .form-select, .form-control {
            border-radius: 14px;
            padding: 12px;
        }
    </style>
</head>

<body>

<nav class="navbar navbar-dark bg-primary px-4">
    <span class="navbar-brand fw-bold">🎓 Scholarship Details</span>
    <div>
        <a href="/student-dashboard" class="btn btn-light btn-sm">Dashboard</a>
        <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
    </div>
</nav>

<div class="container my-5">

    <div class="hero p-4 p-md-5 mb-4">
        <h2 class="fw-bold mb-2">Welcome, <%= student.name %></h2>
        <p class="mb-0">
            Course: <b><%= student.course %></b> |
            Aadhaar: <b><%= student.aadhaar %></b> |
            Phone: <b><%= student.phone %></b>
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card info-card p-4 text-center">
                <h1>📚</h1>
                <h5 class="fw-bold text-primary">Scholarship Type</h5>
                <p class="mb-0">Post-Matric SC/ST Scholarship</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card info-card p-4 text-center">
                <h1>🏫</h1>
                <h5 class="fw-bold text-success">College</h5>
                <p class="mb-0"><%= student.college %></p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card info-card p-4 text-center">
                <h1>✅</h1>
                <h5 class="fw-bold text-danger">Current Status</h5>
                <span class="badge bg-warning text-dark badge-3d"><%= student.status || "Pending" %></span>
            </div>
        </div>

    </div>

    <div class="card glass-card p-4 mt-5">
        <h3 class="fw-bold text-primary mb-3">📌 Choose Academic Year & Student Type</h3>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="fw-bold mb-1">Academic Year</label>
                <select id="year" class="form-select">
                    <option>2026-27</option>
                    <option>2025-26</option>
                    <option>2024-25</option>
                    <option>2023-24</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="fw-bold mb-1">Student Type</label>
                <select id="studentType" class="form-select" onchange="calculateAmount()">
                    <option value="day">Day Scholar</option>
                    <option value="hostel">Hosteller</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="fw-bold mb-1">Course Group</label>
                <select id="courseGroup" class="form-select" onchange="calculateAmount()">
                    <option value="engineering">Engineering / Professional</option>
                    <option value="diploma">Diploma / Polytechnic</option>
                    <option value="degree">Degree / General</option>
                </select>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-3">

        <div class="col-md-6">
            <div class="amount-box p-4">
                <h4 class="fw-bold">💰 Estimated Scholarship Amount</h4>
                <h1 class="fw-bold mt-3">₹<span id="totalAmount">16300</span></h1>
                <p class="mb-0">Amount may vary based on official approval, course group and fee structure.</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card glass-card p-4">
                <h4 class="fw-bold text-primary">📊 Amount Breakdown</h4>

                <table class="table mt-3">
                    <tr>
                        <th>Maintenance Allowance</th>
                        <td>₹<span id="maintenance">12000</span></td>
                    </tr>
                    <tr>
                        <th>Tuition / College Fee</th>
                        <td>₹<span id="tuition">3000</span></td>
                    </tr>
                    <tr>
                        <th>Other Academic Support</th>
                        <td>₹<span id="other">1300</span></td>
                    </tr>
                </table>
            </div>
        </div>

    </div>

    <div class="card glass-card p-4 mt-4">
        <h4 class="fw-bold text-primary">📄 Required Documents</h4>

        <div class="row mt-3">
            <div class="col-md-6">
                <ul>
                    <li>Aadhaar Card</li>
                    <li>Caste Certificate</li>
                    <li>Income Certificate</li>
                    <li>Bank Passbook</li>
                </ul>
            </div>
            <div class="col-md-6">
                <ul>
                    <li>College ID Card</li>
                    <li>Previous Marksheet</li>
                    <li>Admission Receipt</li>
                    <li>Passport Size Photo</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card glass-card p-4 mt-4">
        <h4 class="fw-bold text-primary">🧾 Application Process</h4>

        <ol class="mt-3">
            <li>Student registration completed.</li>
            <li>Student details verified by college/admin.</li>
            <li>Scholarship status updated by admin.</li>
            <li>Payment proof submitted if required.</li>
            <li>Final amount credited after approval.</li>
        </ol>

        <div class="d-flex flex-wrap gap-2 mt-3">
            <a href="/payment" class="btn btn-success fw-bold">💳 Payment / Upload Proof</a>
            <a href="/id-card" class="btn btn-primary fw-bold">🪪 View ID Card</a>
            <a href="/student-dashboard" class="btn btn-dark fw-bold">📊 Dashboard</a>
        </div>
    </div>

</div>

<script>
function calculateAmount() {
    const type = document.getElementById("studentType").value;
    const group = document.getElementById("courseGroup").value;

    let maintenance = 0;
    let tuition = 0;
    let other = 1300;

    if (group === "engineering") {
        maintenance = type === "hostel" ? 17000 : 12000;
        tuition = 3000;
    } else if (group === "diploma") {
        maintenance = type === "hostel" ? 12000 : 8000;
        tuition = 2500;
    } else {
        maintenance = type === "hostel" ? 10000 : 6500;
        tuition = 2000;
    }

    const total = maintenance + tuition + other;

    document.getElementById("maintenance").innerText = maintenance;
    document.getElementById("tuition").innerText = tuition;
    document.getElementById("other").innerText = other;
    document.getElementById("totalAmount").innerText = total;
}

calculateAmount();
</script>

</body>
</html>