<!DOCTYPE html>
<html>
<head>
    <title>WhatsApp Send List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<nav class="navbar navbar-dark bg-success px-4 shadow">
    <span class="navbar-brand fw-bold">📲 WhatsApp Student Message List</span>
    <a href="/dashboard" class="btn btn-light btn-sm">Back</a>
</nav>

<div class="container my-5">

    <div class="card shadow border-0 p-4 mb-4">
        <h4 class="text-success">Message</h4>
        <div class="alert alert-success"><%= message %></div>

        <button onclick="sendSelected()" class="btn btn-success fw-bold">
            🚀 Send Selected Students
        </button>
    </div>

    <div class="card shadow border-0 p-4">
        <h4>Student List</h4>

        <table class="table table-bordered table-hover mt-3">
            <thead class="table-success">
                <tr>
                    <th>
                        <input type="checkbox" id="selectAll" onclick="toggleAll()">
                    </th>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                <% students.forEach(s => { %>
                    <% if(s.phone) { %>
                    <tr>
                        <td>
                            <input type="checkbox"
                                   class="studentCheck"
                                   data-link="https://wa.me/<%= s.phone %>?text=<%= encodeURIComponent(message) %>">
                        </td>

                        <td><%= s.name %></td>
                        <td><%= s.phone %></td>

                        <td>
                            <a class="btn btn-success btn-sm"
                               target="_blank"
                               href="https://wa.me/<%= s.phone %>?text=<%= encodeURIComponent(message) %>">
                                Open WhatsApp
                            </a>
                        </td>
                    </tr>
                    <% } %>
                <% }) %>
            </tbody>
        </table>
    </div>

</div>

<script>
function toggleAll() {
    let selectAll = document.getElementById("selectAll");
    let checks = document.querySelectorAll(".studentCheck");

    checks.forEach(check => {
        check.checked = selectAll.checked;
    });
}

function sendSelected() {
    let selected = document.querySelectorAll(".studentCheck:checked");

    if (selected.length === 0) {
        alert("Please select at least one student");
        return;
    }

    selected.forEach((check, index) => {
        setTimeout(() => {
            window.open(check.dataset.link, "_blank");
        }, index * 1000);
    });
}
</script>

</body>
</html>