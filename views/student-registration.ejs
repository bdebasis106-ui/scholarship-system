<!DOCTYPE html>
<html>
<head>
    <title>Student Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body style="background:#eef3ff;">

<div class="container mt-5">
    <div class="card shadow p-4 mx-auto" style="max-width:600px;">
        <h3 class="text-center text-primary">Student Registration</h3>

        <form method="POST" action="/student-register" class="row g-3">
            <div class="col-md-6">
                <input name="name" class="form-control" placeholder="Student Name" required>
            </div>

            <div class="col-md-6">
                <input name="aadhaar" class="form-control" placeholder="Aadhaar Number" required>
            </div>

            <div class="col-md-6">
                <input name="phone" class="form-control" placeholder="Phone Number" required>
            </div>

            <div class="col-md-6">
                <input name="college" class="form-control" placeholder="College Name" required>
            </div>

            <div class="col-md-6">
                <input name="course" class="form-control" placeholder="Course" required>
            </div>

            <div class="col-md-6">
                <input name="username" class="form-control" placeholder="Create Username" required>
            </div>

            <div class="col-md-6">
                <input name="password" type="password" class="form-control" placeholder="Create Password" required>
            </div>

            <div class="col-12">
                <button class="btn btn-primary w-100">Register</button>
            </div>
        </form>
    </div>
</div>

</body>
</html>